# QuIDE — Environment Variables
# Copy to .env.local and fill in your values

# Supabase (from your project's API settings)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Python simulation service (Railway URL in prod, localhost in dev)
NEXT_PUBLIC_SIMULATION_API_URL=http://localhost:8000

# Shared secret between Next.js → Python service
# Must match SERVICE_API_KEY in Railway env vars
SIMULATION_SERVICE_KEY=dev-key-change-in-prod
